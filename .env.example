# OpenPrime Backend — environment variables
# Copy to `.env` and fill in. Do NOT commit your real `.env`.

# --- Server ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# --- Logging ---
LOG_LEVEL=info
# Transport is auto-detected (console-only in Kubernetes). Override if needed:
# CONSOLE_LOGGING=true
# FILE_LOGGING=false

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openprime
DB_USER=openprime
DB_PASSWORD=change-me

# --- Keycloak (auth) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=openprime
# Comma-separated list of accepted JWT issuers (e.g. internal + public URLs)
KEYCLOAK_JWT_ISSUERS=http://localhost:8080/realms/openprime

# --- Credential encryption ---
# 32-byte key as 64 hex chars:  openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=replace-with-64-hex-chars

# --- Internal services ---
INJECTO_SERVICE_URL=http://localhost:8000
STATECRAFT_SERVICE_URL=http://localhost:8001

# --- Infrastructure templates (repo Injecto pulls to generate IaC) ---
INFRA_TEMPLATES_REPO_URL=https://github.com/devopsgroupeu/openprime-infra-templates.git
INFRA_TEMPLATES_BRANCH=main

# --- AI assistant (AWS Bedrock) ---
AWS_REGION=eu-west-1
BEDROCK_INFERENCE_PROFILE_ARN=

# --- Kubernetes (auto-set in-cluster; leave unset locally) ---
# KUBERNETES_SERVICE_HOST=

# --- TLS (dev only; NEVER enable in production) ---
# NODE_TLS_REJECT_UNAUTHORIZED=0
